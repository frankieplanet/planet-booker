<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>5b4d8e2c-9f6a-4b3e-a8d1-7c5e9f1a2b3d</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Planet Mortgages</ProviderName>
  <DefaultLocale>en-GB</DefaultLocale>
  <DisplayName DefaultValue="Planet Booker"/>
  <Description DefaultValue="Quickly book a new appointment from anywhere in Outlook. Validates against SPL, fires SMS + email confirmation, lands directly in your calendar."/>
  <IconUrl DefaultValue="https://frankieplanet.github.io/planet-booker/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://frankieplanet.github.io/planet-booker/icon-128.png"/>
  <SupportUrl DefaultValue="https://planetmortgages.co.uk"/>

  <AppDomains>
    <AppDomain>https://frankieplanet.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://frankieplanet.github.io/planet-booker/index.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message"/>
    <Rule xsi:type="ItemIs" ItemType="Appointment"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <!-- Function file for any future task-less commands -->
          <FunctionFile resid="functionFile"/>

          <!-- Ribbon button in Inbox / Mail Read pane -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="planetBookerGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="planetBookerButton">
                  <Label resid="buttonLabel"/>
                  <Supertip>
                    <Title resid="buttonTitle"/>
                    <Description resid="buttonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Ribbon button in Compose pane (when writing email) -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="planetBookerGroupCompose">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="planetBookerButtonCompose">
                  <Label resid="buttonLabel"/>
                  <Supertip>
                    <Title resid="buttonTitle"/>
                    <Description resid="buttonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Ribbon button on Appointment (so brokers can also open it from a calendar event) -->
          <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="planetBookerGroupAppt">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="planetBookerButtonAppt">
                  <Label resid="buttonLabel"/>
                  <Supertip>
                    <Title resid="buttonTitle"/>
                    <Description resid="buttonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://frankieplanet.github.io/planet-booker/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://frankieplanet.github.io/planet-booker/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://frankieplanet.github.io/planet-booker/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://frankieplanet.github.io/planet-booker/function.html"/>
        <bt:Url id="taskpaneUrl" DefaultValue="https://frankieplanet.github.io/planet-booker/index.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Planet"/>
        <bt:String id="buttonLabel" DefaultValue="Book Appointment"/>
        <bt:String id="buttonTitle" DefaultValue="Planet Booker"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="buttonDesc" DefaultValue="Open the Planet booking form to create a new appointment with PCID + auto-fire SMS/email."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
